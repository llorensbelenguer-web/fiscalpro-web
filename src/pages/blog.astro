---
import Layout from '../layouts/Layout.astro';
const posts = [
	{ title: 'Guía Completa sobre el IVA', url: '/fiscalpro-web/blog/guia-iva', category: 'Guías', desc: 'Entiende cómo funciona el IVA y tus obligaciones.' },
	{ title: 'Gastos Deducibles para Autónomos', url: '/fiscalpro-web/blog/gastos-deducibles', category: 'Guías', desc: 'Descubre qué puedes desgravar en tu actividad.' },
	{ title: 'Calendario Fiscal 2026', url: '/fiscalpro-web/blog/calendario-fiscal-2026', category: 'Actualidad', desc: 'Fechas clave para no perder ningún plazo.' },
	{ title: 'Cómo darse de alta en el RETA', url: '/fiscalpro-web/blog/alta-reta', category: 'Autónomos', desc: 'Pasos para iniciar tu actividad como autónomo.' },
	{ title: 'Impuesto de Sociedades para PYMES', url: '/fiscalpro-web/blog/impuesto-sociedades', category: 'Empresas', desc: 'Conceptos clave y tipos de gravamen.' },
	{ title: 'Deducciones en la C. Valenciana', url: '/fiscalpro-web/blog/deducciones-comunidad-valenciana', category: 'Guías', desc: 'Ahorra en tu Renta con los beneficios locales.' }
];
---

<Layout title="Blog de Actualidad Fiscal | FiscalPro">
	<main class="max-w-6xl mx-auto py-20 px-6">
		<h1 class="text-4xl font-bold mb-12 text-center">Actualidad y Guías Fiscales</h1>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{posts.map(post => (
				<a href={post.url} class="block p-8 bg-white border border-slate-200 rounded-2xl hover:border-blue-500 transition shadow-sm group">
					<span class="text-blue-600 font-bold uppercase text-xs">{post.category}</span>
					<h2 class="text-2xl font-bold text-slate-900 mt-2 mb-4 group-hover:text-blue-700">{post.title}</h2>
					<p class="text-slate-500 text-sm mb-6 line-clamp-2">{post.desc}</p>
					<span class="text-blue-700 font-medium">Leer más &rarr;</span>
				</a>
			))}
		</div>
	</main>
</Layout>
