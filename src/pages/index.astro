---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FiscalPro | Asesoría Fiscal Estratégica & Optimización">
	<main>
		<!-- 1. HERO PERSUASIVO (Regla de los 5 segundos) -->
		<section class="relative min-h-[95vh] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0 z-0">
				<div class="absolute inset-0 bg-gradient-to-r from-slate-950/95 via-slate-900/70 to-slate-900/30 z-10"></div>
				<div class="w-full h-full bg-cover bg-center bg-fixed" style="background-image: url('https://sc04.alicdn.com/kf/A13aad03856d34efd82e43a2007d5cbabH.jpg');"></div>
			</div>
			
			<div class="relative z-20 max-w-7xl mx-auto px-6 w-full text-left pt-20">
				<div class="max-w-4xl">
					<div class="flex items-center gap-3 mb-8">
						<span class="w-12 h-[2px] bg-blue-500"></span>
						<span class="text-blue-400 font-black text-xs uppercase tracking-[0.4em]">Estrategia Fiscal Boutique</span>
					</div>
					<h1 class="text-6xl md:text-[8rem] font-[950] text-white mb-10 tracking-tighter leading-[0.85] drop-shadow-sm">
						Paga menos. <br/>Vive <span class="text-blue-500">tranquilo.</span>
					</h1>
					<p class="text-xl md:text-3xl text-slate-300 mb-14 max-w-2xl font-light leading-relaxed">
						Ayudamos a <span class="text-white font-bold">Autónomos y PYMES</span> a reducir su impacto impositivo con atención personalizada y reuniones presenciales garantizadas.
					</p>
					
					<div class="flex flex-col sm:flex-row gap-8 items-center">
						<a href="https://wa.me/34697368100?text=Hola%20Llorenç,%20quiero%20una%20auditoria%20fiscal" 
						   target="_blank" 
						   class="group relative inline-flex items-center justify-center gap-4 bg-green-500 text-white px-14 py-8 rounded-[2rem] text-2xl font-black uppercase tracking-tight transition-all hover:bg-green-600 shadow-[0_30px_60px_rgba(34,197,94,0.4)] hover:-translate-y-1">
							<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9L22 4Z"/></svg>
							Solicitar Consulta
						</a>
						<a href="#servicios" class="text-white/80 hover:text-white font-bold text-xl border-b-2 border-white/20 pb-1 transition-all">Ver cómo lo hacemos &darr;</a>
					</div>
				</div>
			</div>

			<!-- 2. ICON ROW (Ventajas Rápidas) -->
			<div class="absolute bottom-10 left-0 w-full z-20">
				<div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-5 gap-4">
					<div class="flex items-center gap-3 bg-white/5 backdrop-blur-md border border-white/10 p-4 rounded-2xl">
						<div class="text-blue-500">
							<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
						</div>
						<span class="text-[10px] font-black text-white/90 uppercase tracking-widest leading-none">Atención 1:1</span>
					</div>
					<div class="flex items-center gap-3 bg-white/5 backdrop-blur-md border border-white/10 p-4 rounded-2xl">
						<div class="text-indigo-400">
							<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<span class="text-[10px] font-black text-white/90 uppercase tracking-widest leading-none">Asesoría Online</span>
					</div>
					<div class="flex items-center gap-3 bg-white/5 backdrop-blur-md border border-white/10 p-4 rounded-2xl">
						<div class="text-green-400">
							<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
						</div>
						<span class="text-[10px] font-black text-white/90 uppercase tracking-widest leading-none">Respuesta Rápida</span>
					</div>
					<div class="flex items-center gap-3 bg-white/5 backdrop-blur-md border border-white/10 p-4 rounded-2xl">
						<div class="text-orange-400">
							<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
						</div>
						<span class="text-[10px] font-black text-white/90 uppercase tracking-widest leading-none">Expertos PYME</span>
					</div>
					<div class="flex items-center gap-3 bg-white/5 backdrop-blur-md border border-white/10 p-4 rounded-2xl hidden md:flex">
						<div class="text-purple-400">
							<svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
						</div>
						<span class="text-[10px] font-black text-white/90 uppercase tracking-widest leading-none">Planificación Anual</span>
					</div>
				</div>
			</div>
		</section>

		<!-- 3. INDICADORES DE CONFIANZA -->
		<section class="py-32 px-6 bg-slate-50 border-y border-slate-100">
			<div class="max-w-7xl mx-auto grid md:grid-cols-4 gap-8">
				<div class="p-8 bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 group hover:-translate-y-2 transition-transform">
					<div class="text-blue-600 font-black text-5xl mb-4 tracking-tighter italic">100%</div>
					<h4 class="text-sm font-black uppercase tracking-widest text-slate-400 mb-4">Compromiso Digital</h4>
					<p class="text-slate-600 font-medium">Gestión documental íntegramente online para tu comodidad total.</p>
				</div>
				<div class="p-8 bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 group hover:-translate-y-2 transition-transform">
					<div class="text-blue-600 font-black text-5xl mb-4 tracking-tighter italic">1:1</div>
					<h4 class="text-sm font-black uppercase tracking-widest text-slate-400 mb-4">Trato Cercano</h4>
					<p class="text-slate-600 font-medium">Sin intermediarios. Hablas directamente con tu asesor experto.</p>
				</div>
				<div class="p-8 bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 group hover:-translate-y-2 transition-transform">
					<div class="text-blue-600 font-black text-5xl mb-4 tracking-tighter italic">+10M</div>
					<h4 class="text-sm font-black uppercase tracking-widest text-slate-400 mb-4">Ahorro Generado</h4>
					<p class="text-slate-600 font-medium">Optimizamos cada euro para que se quede en tu caja de beneficios.</p>
				</div>
				<div class="p-8 bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 group hover:-translate-y-2 transition-transform">
					<div class="text-blue-600 font-black text-5xl mb-4 tracking-tighter italic">24h</div>
					<h4 class="text-sm font-black uppercase tracking-widest text-slate-400 mb-4">Respuesta Max</h4>
					<p class="text-slate-600 font-medium">Tu negocio no espera, nuestras respuestas a tus dudas tampoco.</p>
				</div>
			</div>
		</section>

		<!-- 4. SERVICIOS -->
		<section class="py-32 px-6 max-w-7xl mx-auto" id="servicios">
			<div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8">
				<div class="max-w-2xl">
					<h2 class="text-sm font-black text-blue-600 uppercase tracking-widest mb-4">Soluciones de Negocio</h2>
					<h3 class="text-5xl md:text-7xl font-black text-slate-900 leading-[0.9] tracking-tighter">Impacto real en tus <br/><span class="text-slate-400 italic">finanzas.</span></h3>
				</div>
				<a href="https://wa.me/34697368100" class="px-10 py-5 bg-blue-600 text-white rounded-2xl font-black uppercase text-xs tracking-[0.2em] shadow-xl shadow-blue-200 hover:bg-blue-700 transition-all">Pedir Presupuesto</a>
			</div>

			<div class="grid lg:grid-cols-3 gap-8">
				<!-- Autónomos -->
				<div class="group p-12 bg-white rounded-[3rem] border border-slate-200 hover:border-blue-500 transition-all duration-500 hover:shadow-2xl">
					<div class="text-4xl mb-10 group-hover:scale-125 transition-transform origin-left">💼</div>
					<h4 class="text-3xl font-black mb-6 text-slate-900">Autónomos & Freelance</h4>
					<div class="space-y-6 text-slate-600">
						<div>
							<p class="text-[10px] font-black uppercase text-red-500 mb-1">El Problema</p>
							<p class="font-medium italic">"No sé cuánto pagaré el trimestre que viene y la burocracia me quita horas de trabajo."</p>
						</div>
						<div class="h-[1px] bg-slate-100"></div>
						<div>
							<p class="text-[10px] font-black uppercase text-blue-500 mb-1">Nuestra Solución</p>
							<p class="font-bold text-slate-900">Gestión automatizada y planificación predictiva de ingresos y gastos.</p>
						</div>
						<div>
							<p class="text-[10px] font-black uppercase text-green-500 mb-1">Tu Beneficio</p>
							<p class="text-lg font-black text-slate-900">Máximo ahorro fiscal legal y libertad total para crear.</p>
						</div>
					</div>
				</div>

				<!-- PYMES -->
				<div class="group p-12 bg-slate-900 rounded-[3rem] border border-slate-800 hover:border-blue-500 transition-all duration-500 hover:shadow-2xl">
					<div class="text-4xl mb-10 group-hover:scale-125 transition-transform origin-left">🏢</div>
					<h4 class="text-3xl font-black mb-6 text-white">PYMES & Sociedades</h4>
					<div class="space-y-6 text-slate-400">
						<div>
							<p class="text-[10px] font-black uppercase text-red-400 mb-1">El Problema</p>
							<p class="font-medium italic">"Mi gestoría actual solo pica facturas y no me propone estrategias de ahorro."</p>
						</div>
						<div class="h-[1px] bg-white/10"></div>
						<div>
							<p class="text-[10px] font-black uppercase text-blue-400 mb-1">Nuestra Solución</p>
							<p class="font-bold text-white">Ingeniería fiscal avanzada y optimización del balance de situación.</p>
						</div>
						<div>
							<p class="text-[10px] font-black uppercase text-green-400 mb-1">Tu Beneficio</p>
							<p class="text-lg font-black text-white">Empresa solvente, segura y fiscalmente eficiente.</p>
						</div>
					</div>
				</div>

				<!-- IRPF -->
				<div class="group p-12 bg-white rounded-[3rem] border border-slate-200 hover:border-blue-500 transition-all duration-500 hover:shadow-2xl">
					<div class="text-4xl mb-10 group-hover:scale-125 transition-transform origin-left">⚖️</div>
					<h4 class="text-3xl font-black mb-6 text-slate-900">Especialista Renta</h4>
					<div class="space-y-6 text-slate-600">
						<div>
							<p class="text-[10px] font-black uppercase text-red-500 mb-1">El Problema</p>
							<p class="font-medium italic">"El borrador de Hacienda no incluye mis deducciones de la Comunidad Valenciana."</p>
						</div>
						<div class="h-[1px] bg-slate-100"></div>
						<div>
							<p class="text-[10px] font-black uppercase text-blue-500 mb-1">Nuestra Solución</p>
							<p class="font-bold text-slate-900">Auditoría detallada de gastos en salud, vivienda y sostenibilidad local.</p>
						</div>
						<div>
							<p class="text-[10px] font-black uppercase text-green-500 mb-1">Tu Beneficio</p>
							<p class="text-lg font-black text-slate-900">Devoluciones máximas y 100% de cumplimiento legal.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- 5. TESTIMONIOS (Bloques con Estrellas) -->
		<section class="py-32 px-6 bg-white overflow-hidden">
			<div class="max-w-7xl mx-auto">
				<h2 class="text-center text-4xl md:text-6xl font-black mb-20 tracking-tighter uppercase">Lo que dicen <span class="text-blue-600 italic">nuestros clientes</span></h2>
				
				<div class="grid md:grid-cols-2 gap-8 mb-20">
					<!-- Maricarmen -->
					<div class="p-10 bg-slate-50 rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
						<div class="flex gap-1 mb-6">
							{[1,2,3,4,5].map(() => (
								<svg class="w-6 h-6 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
							))}
						</div>
						<p class="text-xl font-medium text-slate-800 mb-8 italic leading-relaxed">
							"Excelente servicio y una atención impecable durante todo el proceso de mi declaración de Renta. Destaco especialmente su profesionalidad, claridad para explicar cada paso y la confianza que trasmite en todo momento. Sin duda un gestor altamente recomendable."
						</p>
						<div class="flex items-center gap-4">
							<div class="w-14 h-14 bg-blue-600 rounded-full flex items-center justify-center font-black text-white text-xl shadow-lg">M</div>
							<div>
								<p class="font-black text-slate-900 text-lg uppercase tracking-tight">Maricarmen</p>
								<p class="text-xs text-blue-600 font-bold uppercase tracking-widest">Cliente Verificado</p>
							</div>
						</div>
					</div>

					<!-- Martín -->
					<div class="p-10 bg-slate-50 rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
						<div class="flex gap-1 mb-6">
							{[1,2,3,4,5].map(() => (
								<svg class="w-6 h-6 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
							))}
						</div>
						<p class="text-xl font-medium text-slate-800 mb-8 italic leading-relaxed">
							"Muy satisfecho con la declaración de la renta. El trato fue cercano, profesional y eficiente, resolviendo mis dudas con toda claridad y haciendo que el proceso fuera sencillo. Totalmente recomendable."
						</p>
						<div class="flex items-center gap-4">
							<div class="w-14 h-14 bg-slate-900 rounded-full flex items-center justify-center font-black text-white text-xl shadow-lg">M</div>
							<div>
								<p class="font-black text-slate-900 text-lg uppercase tracking-tight">Martín</p>
								<p class="text-xs text-blue-600 font-bold uppercase tracking-widest">Cliente Verificado</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Formulario Interactivo -->
				<div class="max-w-3xl mx-auto bg-slate-950 p-12 md:p-20 rounded-[4rem] shadow-2xl relative overflow-hidden">
					<div class="absolute top-0 right-0 w-64 h-64 bg-blue-600 opacity-10 blur-[100px]"></div>
					<h3 class="text-4xl font-black text-white mb-6 text-center">¿Eres cliente? <span class="text-blue-500 italic">Danos tu opinión</span></h3>
					<p class="text-slate-400 text-center text-lg mb-12">Tu feedback es el motor de nuestra excelencia.</p>
					
					<form class="space-y-8" action="https://formspree.io/f/mqakvjnd" method="POST">
						<div class="grid md:grid-cols-2 gap-8">
							<div class="space-y-2">
								<label class="text-xs font-black uppercase tracking-widest text-slate-500 ml-4">Nombre Completo</label>
								<input type="text" name="name" placeholder="Tu Nombre" required class="w-full bg-white/5 border border-white/10 p-5 rounded-2xl text-white outline-none focus:border-blue-500 transition-colors" />
							</div>
							<div class="space-y-2">
								<label class="text-xs font-black uppercase tracking-widest text-slate-500 ml-4">Valoración</label>
								<select name="rating" required class="w-full bg-white/5 border border-white/10 p-5 rounded-2xl text-white outline-none focus:border-blue-500 transition-colors cursor-pointer">
									<option value="5" class="text-slate-900">⭐⭐⭐⭐⭐ Excelente</option>
									<option value="4" class="text-slate-900">⭐⭐⭐⭐ Muy bueno</option>
									<option value="3" class="text-slate-900">⭐⭐⭐ Bueno</option>
								</select>
							</div>
						</div>
						<div class="space-y-2">
							<label class="text-xs font-black uppercase tracking-widest text-slate-500 ml-4">Tu Experiencia</label>
							<textarea name="comment" rows="5" placeholder="Cuéntanos cómo ha sido trabajar con nosotros..." required class="w-full bg-white/5 border border-white/10 p-5 rounded-2xl text-white outline-none focus:border-blue-500 transition-colors resize-none"></textarea>
						</div>
						<button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-black py-6 rounded-2xl uppercase tracking-[0.2em] text-sm transition-all transform hover:scale-[1.02] shadow-xl shadow-blue-900/20">Publicar mi Opinión</button>
					</form>
				</div>
			</div>
		</section>

		<!-- 6. SOBRE MÍ (Humanización) -->
		<section class="py-32 px-6 bg-slate-50" id="sobre-mi">
			<div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-24 items-center">
				<div class="relative group">
					<div class="absolute -inset-6 bg-blue-600 rounded-[4rem] -z-10 rotate-3 opacity-20 blur-2xl group-hover:rotate-6 transition-all duration-700"></div>
					<img src="https://sc04.alicdn.com/kf/A3195799fed3b4d0490d9deb78284cbcbG.jpg" class="rounded-[3.5rem] shadow-2xl w-full max-w-lg object-cover" alt="Llorenç Belenguer" />
					<div class="absolute -bottom-8 -right-8 bg-white p-8 rounded-3xl shadow-2xl border border-slate-50 hidden md:block text-center">
						<p class="text-xs font-black text-blue-600 uppercase tracking-widest mb-1">Especialista Senior</p>
						<p class="text-2xl font-black text-slate-900 italic">Llorenç Belenguer</p>
					</div>
				</div>
				<div class="space-y-10">
					<h2 class="text-sm font-black text-blue-600 uppercase tracking-widest">Filosofía de Trabajo</h2>
					<h3 class="text-5xl md:text-7xl font-black text-slate-900 leading-[0.9] tracking-tighter">Cercanía real en un mundo digital.</h3>
					<div class="space-y-6 text-xl text-slate-600 font-light leading-relaxed">
						<p>Soy <span class="text-slate-900 font-bold">Graduado en Derecho y Ciencias Políticas</span> con Máster en Asesoría Fiscal Internacional. Mi forma de trabajar es radicalmente opuesta a la gestión masiva.</p>
						<p>Gestiono personalmente cada caso, asegurando que entiendas por qué tomas cada decisión financiera. La confianza no se delega, se construye con resultados y disponibilidad.</p>
					</div>
					<div class="flex gap-10">
						<div>
							<div class="text-4xl font-black text-blue-600 italic">01</div>
							<div class="text-[10px] font-black uppercase text-slate-400 tracking-[0.2em] mt-2 text-center">Asesor</div>
						</div>
						<div class="w-[1px] bg-slate-100"></div>
						<p class="text-lg font-bold text-slate-800 flex items-center italic">"Tu tranquilidad es mi éxito."</p>
					</div>
				</div>
			</div>
		</section>

		<!-- 10. FINAL CONVERSION -->
		<section class="bg-blue-600 py-32 px-6 text-center relative overflow-hidden">
			<div class="absolute top-0 left-0 w-full h-full opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
			<div class="relative z-10 max-w-5xl mx-auto">
				<h2 class="text-5xl md:text-[8rem] font-[1000] text-white mb-10 tracking-tighter leading-none italic">¿HABLAMOS?</h2>
				<p class="text-2xl md:text-4xl text-blue-100 mb-20 font-light max-w-3xl mx-auto">Toma hoy la decisión que salvará tus beneficios al cierre de año.</p>
				<a href="https://wa.me/34697368100?text=Hola%20Llorenç,%20he%20visto%20la%20web%20y%20quiero%20empezar" 
				   class="inline-flex items-center gap-6 bg-slate-950 text-white px-16 py-10 rounded-[2.5rem] text-2xl md:text-5xl font-black uppercase transition-all hover:scale-105 shadow-[0_40px_80px_rgba(0,0,0,0.3)]">
					<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9L22 4Z"/></svg>
					WhatsApp Directo
				</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	.hero-valencia {
		background-attachment: fixed;
		background-position: center;
		background-size: cover;
