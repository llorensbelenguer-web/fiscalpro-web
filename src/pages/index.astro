---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FiscalPro | Consultoría Fiscal en Valencia">
	<main>
		<!-- Hero Section con imagen fija de Valencia -->
		<section class="relative h-[80vh] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0 z-0">
				<div class="absolute inset-0 bg-slate-900/60 z-10"></div>
				<div class="w-full h-full bg-cover bg-center bg-fixed" style="background-image: url('https://images.unsplash.com/photo-1558431382-27e303142255?auto=format&fit=crop&q=80&w=2000');"></div>
			</div>
			
			<div class="relative z-20 max-w-6xl mx-auto text-center px-6">
				<h1 class="text-6xl md:text-9xl font-black text-white mb-4 tracking-tighter drop-shadow-2xl">
					FISCAL<span class="text-blue-500">PRO</span>
				</h1>
				<h2 class="text-2xl md:text-4xl font-bold text-white/90 mb-8 uppercase tracking-widest">
					Valencia · Consultoría de Alto Nivel
				</h2>
				<div class="flex flex-col sm:row justify-center gap-4">
					<a href="/fiscalpro-web/contacto" class="px-10 py-4 bg-blue-600 text-white rounded-full font-bold hover:bg-blue-500 transition-all shadow-xl">
						Contactar Ahora
					</a>
					<a href="https://wa.me/34697368100" target="_blank" class="px-10 py-4 bg-green-600 text-white rounded-full font-bold hover:bg-green-500 transition-all flex items-center justify-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9L22 4Z"/></svg>
						WhatsApp Directo
					</a>
				</div>
			</div>
		</section>

		<!-- Sección de Pestañas Mejorada -->
		<section class="max-w-6xl mx-auto py-24 px-6" id="servicios-tabs">
			<div class="bg-white rounded-2xl shadow-2xl border border-slate-200 overflow-hidden">
				<!-- Menú de Pestañas -->
				<div class="flex flex-wrap bg-slate-900">
					<button class="tab-btn flex-1 py-6 px-4 font-bold text-white/60 hover:text-white transition-all border-b-4 border-transparent active-tab-new" data-target="autonomos">
						AUTÓNOMOS
					</button>
					<button class="tab-btn flex-1 py-6 px-4 font-bold text-white/60 hover:text-white transition-all border-b-4 border-transparent" data-target="pymes">
						PYMES
					</button>
					<button class="tab-btn flex-1 py-6 px-4 font-bold text-white/60 hover:text-white transition-all border-b-4 border-transparent" data-target="irpf">
						GESTIÓN IRPF
					</button>
					<button class="tab-btn flex-1 py-6 px-4 font-bold text-white/60 hover:text-white transition-all border-b-4 border-transparent" data-target="auditoria">
						AUDITORÍA
					</button>
				</div>

				<!-- Contenedor de Contenidos -->
				<div class="p-8 md:p-16 min-h-[450px]">
					<div id="autonomos" class="tab-pane block">
						<div class="grid md:grid-cols-2 gap-12 items-center">
							<div class="space-y-6">
								<h3 class="text-4xl font-black text-slate-900">Autónomos</h3>
								<p class="text-xl text-slate-600">Gestión fiscal completa para que solo te preocupes de tu trabajo.</p>
								<ul class="space-y-3 text-slate-700 font-medium">
									<li>• Altas en 24 horas</li>
									<li>• Trimestrales (IVA/IRPF)</li>
									<li>• Libros de registro</li>
								</ul>
							</div>
							<img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&q=80&w=800" class="rounded-xl shadow-lg h-80 w-full object-cover" alt="Autónomos" />
						</div>
					</div>

					<div id="pymes" class="tab-pane hidden">
						<div class="grid md:grid-cols-2 gap-12 items-center">
							<div class="space-y-6">
								<h3 class="text-4xl font-black text-slate-900">PYMES</h3>
								<p class="text-xl text-slate-600">Estructura profesional para el crecimiento de tu empresa.</p>
								<ul class="space-y-3 text-slate-700 font-medium">
									<li>• Impuesto de Sociedades</li>
									<li>• Cuentas Anuales</li>
									<li>• Planificación estratégica</li>
								</ul>
							</div>
							<img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=800" class="rounded-xl shadow-lg h-80 w-full object-cover" alt="PYMES" />
						</div>
					</div>

					<div id="irpf" class="tab-pane hidden">
						<div class="grid md:grid-cols-2 gap-12 items-center">
							<div class="space-y-6">
								<h3 class="text-4xl font-black text-slate-900">Gestión de IRPF</h3>
								<p class="text-xl text-slate-600">Maximizamos tus deducciones en la Comunidad Valenciana.</p>
								<ul class="space-y-3 text-slate-700 font-medium">
									<li>• Renta y Patrimonio</li>
									<li>• Deducciones Autonómicas</li>
									<li>• Revisión de borradores</li>
								</ul>
							</div>
							<!-- FOTO ESPECÍFICA IRPF -->
							<img src="https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?auto=format&fit=crop&q=80&w=800" class="rounded-xl shadow-lg h-80 w-full object-cover" alt="IRPF Valencia" />
						</div>
					</div>

					<div id="auditoria" class="tab-pane hidden">
						<div class="grid md:grid-cols-2 gap-12 items-center">
							<div class="space-y-6">
								<h3 class="text-4xl font-black text-slate-900">Auditoría</h3>
								<p class="text-xl text-slate-600">Seguridad jurídica ante cualquier inspección.</p>
								<ul class="space-y-3 text-slate-700 font-medium">
									<li>• Defensa ante la AEAT</li>
									<li>• Auditoría preventiva</li>
									<li>• Recursos administrativos</li>
								</ul>
							</div>
							<img src="https://images.unsplash.com/photo-1554224154-71917b212330?auto=format&fit=crop&q=80&w=800" class="rounded-xl shadow-lg h-80 w-full object-cover" alt="Auditoría" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Footer de Contacto Rápido -->
		<section class="bg-slate-50 py-16 border-t border-slate-200">
			<div class="max-w-4xl mx-auto text-center px-6">
				<h2 class="text-3xl font-bold mb-8">¿Hablamos?</h2>
				<a href="https://wa.me/34697368100" class="inline-flex items-center gap-4 bg-green-500 hover:bg-green-600 text-white px-8 py-5 rounded-2xl text-2xl font-bold transition-transform hover:scale-105 shadow-xl">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9L22 4Z"/></svg>
					WhatsApp: 697 368 100
				</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	.active-tab-new {
		@apply border-blue-500 text-white bg-slate-800/50;
	}
	.tab-pane {
		animation: slideIn 0.3s ease-out;
	}
	@keyframes slideIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>

<script is:inline>
	const buttons = document.querySelectorAll('.tab-btn');
	const panes = document.querySelectorAll('.tab-pane');

	buttons.forEach(btn => {
		btn.addEventListener('click', () => {
			const target = btn.getAttribute('data-target');

			// Botones
			buttons.forEach(b => b.classList.remove('active-tab-new', 'text-white'));
			btn.classList.add('active-tab-new', 'text-white');

			// Contenidos (Ocultar todos y mostrar solo el seleccionado)
			panes.forEach(p => {
				if (p.id === target) {
					p.classList.remove('hidden');
					p.classList.add('block');
				} else {
					p.classList.add('hidden');
					p.classList.remove('block');
				}
			});
		});
	});
</script>
