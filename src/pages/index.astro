---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FiscalPro | Asesoría Fiscal de Alto Impacto">
	<main>
		<!-- Hero Section Ultra-Directa (Regla de los 5 segundos) -->
		<section class="hero-valencia relative h-[90vh] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0 bg-slate-900/50 z-10"></div>
			<div class="relative z-20 max-w-6xl mx-auto text-center px-6">
				<h1 class="text-4xl md:text-7xl font-black text-white mb-6 leading-tight drop-shadow-2xl">
					Reduzco tu <span class="text-blue-400">Impacto Impositivo</span> con Atención Presencial
				</h1>
				<p class="text-xl md:text-2xl text-white mb-12 max-w-3xl mx-auto font-medium">
					Asesoramiento especializado para <span class="underline decoration-blue-500 decoration-4">Autónomos, Nativos Digitales y PYMES</span>. 
					Disponibilidad inmediata y una reunión presencial garantizada al mes.
				</p>
				
				<!-- BOTÓN ENORME WHATSAPP -->
				<div class="mt-8">
					<a href="https://wa.me/34697368100?text=Hola,%20me%20gustaría%20solicitar%20mi%20primera%20consulta%20fiscal" 
					   target="_blank" 
					   class="inline-flex items-center gap-4 bg-green-500 hover:bg-green-600 text-white px-8 md:px-16 py-6 md:py-10 rounded-full text-2xl md:text-4xl font-black uppercase tracking-tighter transition-all hover:scale-105 shadow-[0_20px_50px_rgba(34,197,94,0.4)] animate-pulse">
						<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9L22 4Z"/></svg>
						¡SOLICITA TU PRIMERA CONSULTA POR WHATSAPP!
					</a>
				</div>
			</div>
		</section>

		<!-- Sección de Pestañas Mejorada -->
		<section class="max-w-7xl mx-auto py-24 px-6" id="servicios-tabs">
			<div class="text-center mb-16">
				<h2 class="text-5xl font-black text-slate-900 mb-4 uppercase">¿Cómo te ayudo a ahorrar?</h2>
				<div class="w-32 h-2 bg-blue-600 mx-auto rounded-full"></div>
			</div>

			<div class="bg-white rounded-[2rem] shadow-2xl border border-slate-200 overflow-hidden">
				<div class="flex flex-wrap bg-slate-900 p-2 gap-2">
					<button class="tab-btn flex-1 py-6 px-4 font-black text-sm tracking-widest text-white/60 hover:text-white transition-all rounded-xl active-tab-new uppercase" data-target="autonomos">Autónomos</button>
					<button class="tab-btn flex-1 py-6 px-4 font-black text-sm tracking-widest text-white/60 hover:text-white transition-all rounded-xl uppercase" data-target="pymes">Empresarios</button>
					<button class="tab-btn flex-1 py-6 px-4 font-black text-sm tracking-widest text-white/60 hover:text-white transition-all rounded-xl uppercase" data-target="irpf">Especialista IRPF</button>
					<button class="tab-btn flex-1 py-6 px-4 font-black text-sm tracking-widest text-white/60 hover:text-white transition-all rounded-xl uppercase" data-target="nosotros">Sobre Mí</button>
				</div>

				<div class="p-8 md:p-20 min-h-[550px] bg-white text-left">
					<!-- Contenidos simplificados y directos -->
					<div id="autonomos" class="tab-pane block">
						<div class="grid md:grid-cols-2 gap-16 items-center">
							<div class="space-y-8">
								<h3 class="text-5xl font-black text-blue-900 leading-tight">Para el Autónomo Actual</h3>
								<p class="text-2xl text-slate-600">Disponibilidad inmediata para resolver tus dudas de IVA e IRPF. Reunión presencial mensual para revisar tu negocio.</p>
								<ul class="space-y-4 text-xl text-slate-800">
									<li class="flex items-center gap-4">💎 Reducción real de la carga fiscal</li>
									<li class="flex items-center gap-4">📍 Reuniones en Valencia presenciales</li>
									<li class="flex items-center gap-4">📱 Consultas vía WhatsApp ilimitadas</li>
								</ul>
							</div>
							<img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&q=80&w=800" class="rounded-2xl shadow-2xl h-96 w-full object-cover" alt="Autónomos" />
						</div>
					</div>

					<div id="pymes" class="tab-pane hidden">
						<div class="grid md:grid-cols-2 gap-16 items-center">
							<div class="space-y-8">
								<h3 class="text-5xl font-black text-blue-900 leading-tight">Pequeños Empresarios</h3>
								<p class="text-2xl text-slate-600">Asesoramiento en materia tributaria para reducir el impacto impositivo de tu sociedad.</p>
								<ul class="space-y-4 text-xl text-slate-800">
									<li>📈 Optimización del Impuesto de Sociedades</li>
									<li>📋 Cuentas Anuales con rigor técnico</li>
									<li>🤝 Trato humano y cercano, sin intermediarios</li>
								</ul>
							</div>
							<img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=800" class="rounded-2xl shadow-2xl h-96 w-full object-cover" alt="PYMES" />
						</div>
					</div>

					<div id="irpf" class="tab-pane hidden">
						<div class="grid md:grid-cols-2 gap-16 items-center">
							<div class="space-y-8">
								<h3 class="text-5xl font-black text-blue-900 leading-tight">Especialista IRPF</h3>
								<p class="text-2xl text-slate-600">Especializado en IRPF y deducciones de la Comunidad Valenciana.</p>
								<ul class="space-y-4 text-xl text-slate-800">
									<li>🏡 Deducción por vivienda y alquiler</li>
									<li>🦷 Gastos médicos y deportivos</li>
									<li>🪙 Fiscalidad de activos digitales</li>
								</ul>
							</div>
							<img src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&q=80&w=800" class="rounded-2xl shadow-2xl h-96 w-full object-cover" alt="IRPF Valencia" />
						</div>
					</div>

					<div id="nosotros" class="tab-pane hidden">
						<div class="grid md:grid-cols-2 gap-16 items-center">
							<div class="space-y-8">
								<h3 class="text-5xl font-black text-blue-900 leading-tight">Sobre Mí</h3>
								<div class="space-y-4">
									<h4 class="text-3xl font-bold text-slate-800">Llorenç Belenguer Benlloch</h4>
									<p class="text-xl text-slate-600 leading-relaxed">
										Grado en Derecho y Ciencias Políticas con Máster en Asesoría Fiscal Internacional. 
										Experto en reducción de carga fiscal para autónomos y nativos digitales.
									</p>
									<p class="text-lg text-blue-700 font-semibold italic">"Atención personalizada: Yo mismo gestiono tu expediente, sin pasar por terceros."</p>
								</div>
							</div>
							<img src="https://sc04.alicdn.com/kf/A3195799fed3b4d0490d9deb78284cbcbG.jpg" class="rounded-2xl shadow-2xl h-[500px] w-full object-cover" alt="Llorenç Belenguer" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Footer con Datos Legales Reales -->
		<footer class="bg-slate-900 text-white py-16 px-6">
			<div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">
				<div>
					<h3 class="text-2xl font-black mb-4">FISCALPRO</h3>
					<p class="text-slate-400">Llorenç Belenguer Benlloch<br/>NIF: 29217203G<br/>Valencia, España</p>
				</div>
				<div>
					<h4 class="font-bold mb-4 uppercase">Contacto</h4>
					<p class="text-slate-400">llorensbelenguer@hotmail.com<br/>WhatsApp: 697 368 100</p>
				</div>
				<div>
					<h4 class="font-bold mb-4 uppercase">Legal</h4>
					<ul class="text-slate-400 space-y-2">
						<li><a href="/fiscalpro-web/aviso-legal/">Aviso Legal</a></li>
						<li><a href="/fiscalpro-web/privacidad/">Privacidad y Cookies</a></li>
					</ul>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<style>
	.hero-valencia {
		background-image: url('https://sc04.alicdn.com/kf/A13aad03856d34efd82e43a2007d5cbabH.jpg');
		background-attachment: fixed;
		background-position: center;
		background-size: cover;
	}
	@media (max-width: 768px) { .hero-valencia { background-attachment: scroll; } }
	
	.active-tab-new {
		background-color: #ffffff !important;
		color: #1e3a8a !important;
		opacity: 1 !important;
		border-bottom: 4px solid #3b82f6;
	}
	.tab-pane { animation: fadeInScale 0.4s ease-out; }
	@keyframes fadeInScale {
		from { opacity: 0; transform: scale(0.98); }
		to { opacity: 1; transform: scale(1); }
	}
</style>

<script is:inline>
	function initTabs() {
		const buttons = document.querySelectorAll('.tab-btn');
		const panes = document.querySelectorAll('.tab-pane');

		buttons.forEach(btn => {
			btn.addEventListener('click', () => {
				const target = btn.getAttribute('data-target');
				buttons.forEach(b => b.classList.remove('active-tab-new'));
				btn.classList.add('active-tab-new');
				panes.forEach(p => {
					if (p.id === target) {
						p.classList.remove('hidden');
						p.classList.add('block');
					} else {
						p.classList.add('hidden');
						p.classList.remove('block');
					}
				});
			});
		});
	}
	document.addEventListener('astro:page-load', initTabs);
	initTabs();
</script>
