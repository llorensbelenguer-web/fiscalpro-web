<style>
	.active-tab-v2 {
		background-color: #1e3a8a !important; /* blue-900 */
		color: white !important;
		box-shadow: 0 10px 40px rgba(30, 58, 138, 0.3);
		transform: scale(1.02);
	}
	.active-tab-v2 .text-sm { color: #93c5fd !important; }

	.tab-pane { animation: fadeInScale 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
	@keyframes fadeInScale {
		from { opacity: 0; transform: translateY(20px) scale(0.98); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}
	
	.animate-fade-in-up {
		animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}
	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(60px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>

<script is:inline>
	function initTabsV2() {
		const buttons = document.querySelectorAll('.tab-btn');
		const panes = document.querySelectorAll('.tab-pane');

		buttons.forEach(btn => {
			btn.addEventListener('click', () => {
				const target = btn.getAttribute('data-target');
				buttons.forEach(b => b.classList.remove('active-tab-v2'));
				btn.classList.add('active-tab-v2');
				panes.forEach(p => {
					if (p.id === target) {
						p.classList.remove('hidden');
						p.classList.add('block');
					} else {
						p.classList.add('hidden');
						p.classList.remove('block');
					}
				});
			});
		});
	}
	document.addEventListener('astro:page-load', initTabsV2);
	initTabsV2();
</script>
