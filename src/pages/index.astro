---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FiscalPro | Asesoría Fiscal de Vanguardia">
	<main>
		<!-- Hero Section con gradiente moderno -->
		<section class="relative py-24 px-6 overflow-hidden bg-white">
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full opacity-10 pointer-events-none">
				<div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
				<div class="absolute top-0 right-1/4 w-96 h-96 bg-indigo-400 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
			</div>
			
			<div class="relative max-w-5xl mx-auto text-center">
				<span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold tracking-wide text-blue-600 uppercase bg-blue-50 rounded-full">Consultoría Inteligente</span>
				<h1 class="text-5xl md:text-7xl font-black text-slate-900 mb-8 tracking-tight">
					Simplificamos tu <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">Gestión Fiscal</span>
				</h1>
				<p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto leading-relaxed">
					La asesoría que se adapta a los nuevos tiempos. Especialistas en optimización tributaria para el ecosistema digital y empresarial.
				</p>
				<div class="flex flex-col sm:flex-row justify-center gap-4">
					<a href="/fiscalpro-web/contacto" class="px-8 py-4 bg-slate-900 text-white rounded-2xl font-bold hover:bg-blue-700 transition-all transform hover:-translate-y-1 shadow-xl">
						Solicitar Auditoría Gratis
					</a>
					<a href="/fiscalpro-web/calculadora" class="px-8 py-4 bg-white text-slate-900 border-2 border-slate-200 rounded-2xl font-bold hover:border-blue-600 hover:text-blue-600 transition-all transform hover:-translate-y-1">
						Probar Calculadora
					</a>
				</div>
			</div>
		</section>

		<!-- Sección de Pestañas Interactivas -->
		<section class="max-w-6xl mx-auto py-20 px-6">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-slate-900">Nuestras Áreas de Experto</h2>
				<p class="text-slate-500 mt-2">Haz clic en cada pestaña para conocer los detalles</p>
			</div>

			<div class="bg-white rounded-3xl shadow-2xl border border-slate-100 overflow-hidden">
				<!-- Navegación de Pestañas -->
				<div class="flex border-b border-slate-100 bg-slate-50/50">
					<button class="tab-btn flex-1 py-5 px-4 font-bold text-slate-500 border-b-2 border-transparent transition-all hover:bg-white active-tab" data-tab="autonomos">
						💼 Autónomos
					</button>
					<button class="tab-btn flex-1 py-5 px-4 font-bold text-slate-500 border-b-2 border-transparent transition-all hover:bg-white" data-tab="pymes">
						🏢 PYMES
					</button>
					<button class="tab-btn flex-1 py-5 px-4 font-bold text-slate-500 border-b-2 border-transparent transition-all hover:bg-white" data-tab="auditoria">
						⚖️ Auditoría
					</button>
				</div>

				<!-- Contenido de Pestañas -->
				<div class="p-8 md:p-12">
					<div id="autonomos" class="tab-content block animate-fadeIn">
						<div class="grid md:grid-cols-2 gap-12 items-center">
							<div>
								<h3 class="text-3xl font-bold mb-4 text-blue-900">Para el profesional independiente</h3>
								<p class="text-slate-600 mb-6 text-lg">Olvídate de los papeles y las facturas. Gestionamos tu día a día para que maximices tus ingresos y minimices tus impuestos.</p>
								<ul class="space-y-4">
									<li class="flex items-start gap-3">
										<span class="bg-blue-100 p-1 rounded-full text-blue-600 text-xs mt-1">✓</span>
										<div><strong>Alta Express:</strong> Hacienda y Seguridad Social en 24h.</div>
									</li>
									<li class="flex items-start gap-3">
										<span class="bg-blue-100 p-1 rounded-full text-blue-600 text-xs mt-1">✓</span>
										<div><strong>Optimización IRPF:</strong> Aplicamos todas las deducciones posibles.</div>
									</li>
								</ul>
							</div>
							<div class="bg-blue-50 rounded-2xl p-8 border border-blue-100">
								<h4 class="font-bold mb-4">Pack Autónomo desde</h4>
								<div class="text-5xl font-black text-blue-600 mb-2">49€<span class="text-sm font-normal text-slate-400">/mes</span></div>
								<p class="text-sm text-slate-500">Incluye asesoría ilimitada por WhatsApp y presentación de todos los modelos.</p>
							</div>
						</div>
					</div>

					<div id="pymes" class="tab-content hidden animate-fadeIn">
						<div class="grid md:grid-cols-2 gap-12 items-center">
							<div>
								<h3 class="text-3xl font-bold mb-4 text-indigo-900">Escalabilidad para tu Empresa</h3>
								<p class="text-slate-600 mb-6 text-lg">Servicio integral de contabilidad y fiscalidad para sociedades que buscan un partner estratégico.</p>
								<ul class="space-y-4">
									<li class="flex items-start gap-3">
										<span class="bg-indigo-100 p-1 rounded-full text-indigo-600 text-xs mt-1">✓</span>
										<div><strong>Impuesto de Sociedades:</strong> Estrategias de ahorro anual.</div>
									</li>
									<li class="flex items-start gap-3">
										<span class="bg-indigo-100 p-1 rounded-full text-indigo-600 text-xs mt-1">✓</span>
										<div><strong>Cuentas Anuales:</strong> Gestión completa ante el Registro Mercantil.</div>
									</li>
								</ul>
							</div>
							<div class="bg-indigo-50 rounded-2xl p-8 border border-indigo-100">
								<h4 class="font-bold mb-4">Consultoría PYME</h4>
								<div class="text-5xl font-black text-indigo-600 mb-2">Consultar</div>
								<p class="text-sm text-slate-500">Presupuestos personalizados según volumen de facturación y empleados.</p>
							</div>
						</div>
					</div>

					<div id="auditoria" class="tab-content hidden animate-fadeIn">
						<div class="text-center max-w-2xl mx-auto py-8">
							<h3 class="text-3xl font-bold mb-4">Blindaje ante la Administración</h3>
							<p class="text-slate-600 text-lg mb-8">Protegemos tu patrimonio y tu negocio ante posibles inspecciones y requerimientos de la AEAT.</p>
							<div class="grid grid-cols-2 gap-4">
								<div class="p-4 border border-slate-100 rounded-xl bg-slate-50">Defensa en Inspecciones</div>
								<div class="p-4 border border-slate-100 rounded-xl bg-slate-50">Recursos de Alzada</div>
								<div class="p-4 border border-slate-100 rounded-xl bg-slate-50">Auditoría Interna</div>
								<div class="p-4 border border-slate-100 rounded-xl bg-slate-50">Compliance Fiscal</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Testimonios / Franja de Confianza -->
		<section class="bg-slate-900 py-16">
			<div class="max-w-6xl mx-auto px-6 flex flex-wrap justify-center gap-12 text-center">
				<div class="w-40">
					<div class="text-3xl font-bold text-white">+500</div>
					<div class="text-slate-400 text-sm">Autónomos</div>
				</div>
				<div class="w-40">
					<div class="text-3xl font-bold text-white">+10M€</div>
					<div class="text-slate-400 text-sm">Ahorrados</div>
				</div>
				<div class="w-40">
					<div class="text-3xl font-bold text-white">100%</div>
					<div class="text-slate-400 text-sm">Online</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.active-tab {
		@apply border-blue-600 text-blue-600 bg-white;
	}
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-fadeIn {
		animation: fadeIn 0.4s ease-out forwards;
	}
</style>

<script is:inline>
	const tabs = document.querySelectorAll('.tab-btn');
	const contents = document.querySelectorAll('.tab-content');

	tabs.forEach(tab => {
		tab.addEventListener('click', () => {
			const target = tab.getAttribute('data-tab');

			// Update buttons
			tabs.forEach(t => t.classList.remove('active-tab', 'text-blue-600', 'border-blue-600'));
			tab.classList.add('active-tab', 'text-blue-600', 'border-blue-600');

			// Update content
			contents.forEach(c => {
				if (c.id === target) {
					c.classList.remove('hidden');
					c.classList.add('block');
				} else {
					c.classList.add('hidden');
					c.classList.remove('block');
				}
			});
		});
	});
</script>
