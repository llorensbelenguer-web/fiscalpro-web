---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
---

<Layout title="Blog de Actualidad Fiscal | FiscalPro">
	<main class="max-w-6xl mx-auto py-20 px-6">
		<h1 class="text-4xl font-bold mb-12">Actualidad Fiscal</h1>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			{posts.map(post => (
				<a href={`/fiscalpro-web/blog/${post.slug}`} class="block p-8 bg-white border border-slate-200 rounded-2xl hover:border-blue-500 transition shadow-sm">
					<span class="text-blue-600 font-bold uppercase text-xs">{post.data.category}</span>
					<h2 class="text-2xl font-bold text-slate-900 mt-2 mb-4">{post.data.title}</h2>
					<p class="text-slate-500 text-sm mb-4 line-clamp-2">{post.data.description}</p>
					<div class="flex justify-between items-center">
						<span class="text-slate-400 text-xs">{post.data.date}</span>
						<span class="text-blue-700 font-medium">Leer más &rarr;</span>
					</div>
				</a>
			))}
		</div>
	</main>
</Layout>
