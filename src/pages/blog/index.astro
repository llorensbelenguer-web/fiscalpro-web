---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('blog');
---

<Layout title="Blog de Actualidad Fiscal | FiscalPro">
	<main class="max-w-6xl mx-auto py-24 px-6">
		<div class="text-center mb-16">
			<h1 class="text-5xl font-black text-slate-900 mb-4">Actualidad Fiscal</h1>
			<p class="text-xl text-slate-600">Guías y novedades para tu tranquilidad tributaria.</p>
			<div class="w-20 h-1 bg-blue-600 mx-auto mt-6"></div>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
			{posts.map(post => (
				<a href={`/fiscalpro-web/blog/${post.slug}/`} class="group bg-white border border-slate-200 rounded-3xl overflow-hidden hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
					<div class="p-8">
						<span class="inline-block px-3 py-1 bg-blue-50 text-blue-600 text-xs font-bold rounded-full mb-4 uppercase tracking-wider">
							{post.data.category}
						</span>
						<h2 class="text-2xl font-bold text-slate-900 mb-4 group-hover:text-blue-700 transition-colors">
							{post.data.title}
						</h2>
						<p class="text-slate-500 text-sm mb-6 line-clamp-3">
							{post.data.description}
						</p>
						<div class="flex items-center justify-between mt-auto">
							<span class="text-slate-400 text-xs">{post.data.date}</span>
							<span class="text-blue-600 font-bold group-hover:translate-x-2 transition-transform">
								Leer guía &rarr;
							</span>
						</div>
					</div>
				</a>
			))}
		</div>
	</main>
</Layout>
