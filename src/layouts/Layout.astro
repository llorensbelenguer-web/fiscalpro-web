---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="FiscalPro - Consultoría Fiscal Estratégica en Valencia para Autónomos y PYMES" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-white text-slate-900 font-['Inter',sans-serif] antialiased selection:bg-blue-100 selection:text-blue-900">
		<!-- Navegación de Alta Gama -->
		<nav class="bg-white/80 backdrop-blur-xl border-b border-slate-100 py-5 px-6 flex justify-between items-center sticky top-0 z-[100]">
			<a href="/fiscalpro-web/" class="flex items-center gap-2 group">
				<div class="bg-blue-600 text-white p-2 rounded-xl shadow-lg shadow-blue-200 group-hover:scale-110 transition-transform">
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
				</div>
				<span class="text-2xl font-black tracking-tighter text-slate-900 uppercase">FISCAL<span class="text-blue-600">PRO</span></span>
			</a>
			<div class="hidden lg:flex items-center gap-10">
				<a href="/fiscalpro-web/servicios/" class="text-sm font-bold text-slate-500 hover:text-blue-600 transition-colors">Servicios</a>
				<a href="/fiscalpro-web/blog/" class="text-sm font-bold text-slate-500 hover:text-blue-600 transition-colors">Blog</a>
				<a href="/fiscalpro-web/calculadora/" class="text-sm font-bold text-slate-500 hover:text-blue-600 transition-colors">Herramientas</a>
				<a href="https://wa.me/34697368100" class="bg-slate-900 text-white px-8 py-3.5 rounded-full text-xs font-black uppercase tracking-widest hover:bg-blue-600 transition-all shadow-xl shadow-slate-200 hover:-translate-y-0.5 active:translate-y-0">Consulta Gratuita</a>
			</div>
		</nav>

		<slot />

		<!-- Botón Flotante WhatsApp Premium -->
		<a href="https://wa.me/34697368100" 
		   target="_blank" 
		   class="fixed bottom-10 right-10 z-[200] bg-green-500 text-white p-5 rounded-full shadow-[0_20px_50px_rgba(34,197,94,0.4)] hover:scale-110 hover:bg-green-600 transition-all active:scale-95 group">
			<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9L22 4Z"/></svg>
			<span class="absolute right-full mr-5 bg-slate-900 text-white text-[11px] py-2.5 px-5 rounded-full opacity-0 group-hover:opacity-100 transition-all invisible group-hover:visible whitespace-nowrap font-black uppercase tracking-widest">¿Dudas? Chat Directo</span>
		</a>

		<footer class="bg-slate-950 text-white py-32 px-6 border-t border-white/5">
			<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-20">
				<div class="md:col-span-2 space-y-8">
					<h3 class="text-4xl font-black mb-6 tracking-tighter italic">FISCALPRO</h3>
					<p class="text-slate-400 text-xl max-w-md leading-relaxed font-light">
						No somos una gestoría tradicional. Somos arquitectos de tu estrategia fiscal en Valencia.
					</p>
					<div class="flex flex-wrap gap-4">
						<div class="px-5 py-3 bg-white/5 rounded-2xl border border-white/10 text-xs font-bold uppercase tracking-widest text-blue-400">Llorenç Belenguer Benlloch</div>
						<div class="px-5 py-3 bg-white/5 rounded-2xl border border-white/10 text-xs font-bold uppercase tracking-widest text-slate-500">NIF: 29217203G</div>
					</div>
				</div>
				<div class="space-y-6">
					<h4 class="text-xs font-black uppercase tracking-[0.2em] text-blue-500">Navegación</h4>
					<ul class="space-y-4 text-slate-400 font-semibold text-sm">
						<li><a href="/fiscalpro-web/servicios/" class="hover:text-white transition-colors">Nuestros Servicios</a></li>
						<li><a href="/fiscalpro-web/blog/" class="hover:text-white transition-colors">Guías y Actualidad</a></li>
						<li><a href="/fiscalpro-web/calculadora/" class="hover:text-white transition-colors">Calculadora de IVA</a></li>
					</ul>
				</div>
				<div class="space-y-6">
					<h4 class="text-xs font-black uppercase tracking-[0.2em] text-blue-500">Legal</h4>
					<ul class="space-y-4 text-slate-400 font-semibold text-sm">
						<li><a href="/fiscalpro-web/aviso-legal/" class="hover:text-white transition-colors">Aviso Legal</a></li>
						<li><a href="/fiscalpro-web/privacidad/" class="hover:text-white transition-colors">Privacidad y Cookies</a></li>
					</ul>
				</div>
			</div>
			<div class="max-w-7xl mx-auto mt-24 pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-slate-600 text-[10px] font-black uppercase tracking-[0.3em]">
				<span>© 2026 FiscalPro Valencia</span>
				<span class="text-blue-900">Built for Excellence</span>
			</div>
		</footer>
	</body>
</html>
