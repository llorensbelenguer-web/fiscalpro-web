---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Asesoría Fiscal Profesional para Autónomos y PYMES" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased">
		<nav class="bg-white/80 backdrop-blur-md border-b border-slate-200 py-4 px-6 flex justify-between items-center sticky top-0 z-50">
			<a href="/fiscalpro-web/" class="flex items-center gap-2">
				<span class="bg-blue-900 text-white p-1.5 rounded-lg">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
				</span>
				<span class="text-2xl font-black tracking-tighter text-slate-900">FISCAL<span class="text-blue-700">PRO</span></span>
			</a>
			<div class="space-x-8 hidden md:flex items-center">
				<a href="/fiscalpro-web/servicios/" class="text-sm font-semibold text-slate-600 hover:text-blue-700 transition-colors">Servicios</a>
				<a href="/fiscalpro-web/blog/" class="text-sm font-semibold text-slate-600 hover:text-blue-700 transition-colors">Actualidad</a>
				<a href="/fiscalpro-web/calculadora/" class="text-sm font-semibold text-slate-600 hover:text-blue-700 transition-colors">Herramientas</a>
				<a href="/fiscalpro-web/contacto/" class="bg-blue-700 text-white px-5 py-2.5 rounded-full text-sm font-bold hover:bg-blue-800 transition-all shadow-md shadow-blue-200">Consultar ahora</a>
			</div>
		</nav>
		<slot />
		<footer class="bg-slate-900 text-white py-12 px-6 mt-20">
			<div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
				<div>
					<h3 class="text-lg font-bold mb-4">FiscalPro</h3>
					<p class="text-slate-400">Asesoría experta para el crecimiento de tu negocio.</p>
				</div>
				<div>
					<h4 class="font-bold mb-4">Legal</h4>
					<ul class="text-slate-400 space-y-2">
						<li><a href="/fiscalpro-web/aviso-legal">Aviso Legal</a></li>
						<li><a href="/fiscalpro-web/privacidad">Privacidad</a></li>
					</ul>
				</div>
			</div>
		</footer>
	</body>
</html>
