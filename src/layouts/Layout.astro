---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Asesoría Fiscal Profesional para Autónomos y PYMES" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans">
		<nav class="bg-white border-b border-slate-200 py-4 px-6 flex justify-between items-center sticky top-0 z-50">
			<a href="/" class="text-xl font-bold text-blue-800">FiscalPro</a>
			<div class="space-x-6 hidden md:flex">
				<a href="/servicios" class="hover:text-blue-600">Servicios</a>
				<a href="/blog" class="hover:text-blue-600">Blog</a>
				<a href="/contacto" class="bg-blue-700 text-white px-4 py-2 rounded-lg hover:bg-blue-800">Contacto</a>
			</div>
		</nav>
		<slot />
		<footer class="bg-slate-900 text-white py-12 px-6 mt-20">
			<div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
				<div>
					<h3 class="text-lg font-bold mb-4">FiscalPro</h3>
					<p class="text-slate-400">Asesoría experta para el crecimiento de tu negocio.</p>
				</div>
				<div>
					<h4 class="font-bold mb-4">Legal</h4>
					<ul class="text-slate-400 space-y-2">
						<li><a href="/aviso-legal">Aviso Legal</a></li>
						<li><a href="/privacidad">Privacidad</a></li>
					</ul>
				</div>
			</div>
		</footer>
	</body>
</html>
